# Horizon3 knowledge corpus — optional email alerts for the curation digest.
# Copy to .env and fill in to receive the twice-weekly digest by email.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=app-password
# SMTP_FROM=you@example.com
# SMTP_TO=you@example.com
# Override the python used by scripts/curate.sh (default: ~/venv/bin/python)
# HORIZON3_PYTHON=/Users/richardwalker/venv/bin/python
