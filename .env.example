# Horizon3 — canonical env template. Copy to `.env` and fill the secrets (never commit `.env`).
# Audited 2026-07-15: this is the COMPLETE set of variables H3 reads at runtime. `.env` is
# self-sufficient — no sibling-repo dependency. Connection values are consumed from UMD.

# --- UMD data seam (read-only consumer). 127.0.0.1 avoids IPv6/GSSAPI flakiness ---
TSDB_HOST=127.0.0.1
TSDB_PORT=5434
TSDB_DB=unified_market_data
TSDB_USER=postgres
TSDB_PASS=devpassword
TIMESCALE_DSN=postgresql://postgres:devpassword@127.0.0.1:5434/unified_market_data
NEO4J_URI=bolt://localhost:7688
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=devpassword
UMD_SRC=/Users/richardwalker/PycharmProjects/unified_market_data/src

# --- secrets (fill these) ---
ANTHROPIC_API_KEY=sk-ant-...          # render/studio/llm.py — the LLM
OPENAI_API_KEY=sk-proj-...            # render/illustration/vangogh.py — gpt-image-1 header art
FRED_API_KEY=...                      # FRED data / ATS calendar
LANGSMITH_API_KEY=lsv2_...            # render/studio/llm.py — LangSmith tracing (recommended)

# --- ATS morning-briefing mailer (Mon+Thu 07:00 via scripts/ats.sh). Gmail App Password. ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=...                         # 16-char Gmail App Password (space-free)
SMTP_FROM=you@gmail.com
SMTP_TO=recipient@example.com         # defaults to richard.walker@lucidate.co.uk if unset

# --- observability + runtime config (code defaults shown; override only if needed) ---
LANGSMITH_PROJECT=horizon3-chart-studio
# LANGSMITH_TRACING is auto-set to "true" by llm.py when a key is present.
VANGOGH_BACKEND=auto                                 # auto|comfyui|openai
HORIZON3_PYTHON=/Users/richardwalker/venv/bin/python # interpreter for cron
# COMFYUI_URL=http://127.0.0.1:8188                  # only if ComfyUI runs elsewhere
