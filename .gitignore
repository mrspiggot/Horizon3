# env / secrets
.env
.env.generated
.venv/

# python
__pycache__/
*.pyc
.pytest_cache/

# corpus: the physical paper copies (sources/) ARE committed — durable
# preservation against link-rot is the whole point. Only regenerated artifacts
# and local run-state are ignored.
knowledge/digests/*.md
knowledge/digests/notify.log.jsonl
knowledge/.curate_state.json
knowledge/candidates.yaml

# generated article/illustration artifacts (regenerated, not source)
output/
render/illustration/.cache/

# editor
.idea/
~$*

# sysdoc versioned snapshots (regenerable)
docs/system/snapshots/
